{
  "name": "presenter-account-web",
  "version": "1.0.0",
  "description": "A web frontend for the presenter account",
  "main": "dist/server.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "sh ./scripts/dev_nodemon.sh",
    "prebuild": "rm -rf ./dist",
    "build:assets": "gulp build",
    "build": "tsc && cp -r src/views dist/ && cp -r src/config dist/",
    "lint": "eslint '{src,test}/**/*'",
    "lint:fix": "eslint '{src,test}/**/*' --fix",
    "coverage": "jest --coverage --coverageProvider=v8 --passWithNoTests",
    "test:coverage": "npm run coverage",
    "test": "jest",
    "start": "node dist/server.js",
    "start:watch": "nodemon",
    "sonarqube-base-branch": "sonar-scanner",
    "sonarqube-pull-request": "sonar-scanner -D sonar.pullrequest.base=main",
    "sonarqube": "branch=$(git rev-parse --symbolic-full-name --abbrev-ref HEAD); if [[ $branch == \"HEAD\" ]]; then echo $branch && npm run sonarqube-base-branch; else echo $branch && npm run sonarqube-pull-request; fi;",
    "chs-dev": "nodemon --legacy-watch",
    "prepare": "husky"
  },
  "dependencies": {
    "@companieshouse/api-sdk-node": "^2.0.293",
    "@companieshouse/ch-node-utils": "^2.1.10",
    "@companieshouse/node-session-handler": "^5.2.6",
    "@companieshouse/structured-logging-node": "^2.0.4",
    "@companieshouse/web-security-node": "^4.4.12",
    "@types/supertest": "^6.0.2",
    "cookie-parser": "^1.4.7",
    "express": "^4.18.3",
    "express-session": "^1.18.0",
    "express-validator": "^7.0.1",
    "govuk-frontend": "^4.7.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.3.2",
    "nunjucks": "3.2.4",
    "private-api-sdk-node": "github:companieshouse/private-api-sdk-node#1.0.87",
    "tslib": "^2.6.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.17",
    "@types/nunjucks": "^3.2.6",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "chalk": "^5.3.0",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "gulp": "^5.0.1",
    "gulp-clean": "^0.4.0",
    "gulp-concat": "^2.6.1",
    "gulp-rename": "^2.1.0",
    "gulp-sass": "^6.0.1",
    "gulp-uglify": "^3.0.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "sass": "^1.93.2",
    "sonarqube-scanner": "^3.3.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-node": "8.10.1",
    "typescript": "4.9.5",
    "typescript-eslint": "^8.46.0"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "@comments devDependencies": {
    "@package sass": [
      "We're using an older version of @sass to suppress deprecation warnings thrown by the @govuk-frontend package during the build",
      "We'll upgrade to the most recent version of @sass after this issue is fixed in the @govuk-frontend package"
    ]
  },
  "nodemonConfig": {
    "watch": [
      "./src",
      "./assets/src"
    ],
    "ext": "ts,js,json,njk,scss,env",
    "legacyWatch": true,
    "ignore": [
      "**/*.test.ts"
    ],
    "exec": "npm run build && source ./dist/config/.env && node dist/server.js"
  },
  "directories": {
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/companieshouse/presenter-account-web.git"
  },
  "keywords": [],
  "bugs": {
    "url": ""
  },
  "homepage": "https://github.com/companieshouse/presenter-account-web#readme",
  "author": "",
  "license": "ISC"
}
